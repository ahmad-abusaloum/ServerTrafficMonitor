<Window x:Class="ServerTrafficMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ServerTrafficMonitor.Models"
        Title="Server Traffic Monitor" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>
    </Window.Resources>

    <DockPanel>

        <!-- ================= Top toolbar ================= -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderClr}"
                BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛰" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="Server Traffic Monitor" FontSize="16" FontWeight="SemiBold" Margin="0,0,20,0"/>
                    <Button Content="{Binding PauseLabel}" Command="{Binding TogglePauseCommand}" MinWidth="92"/>
                    <Button Content="🗑  Clear" Command="{Binding ClearCommand}"/>
                    <Button Content="⬇  Export CSV" Command="{Binding ExportCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding ShowElevationWarning, Converter={StaticResource B2V}}">
                    <TextBlock Text="⚠" Foreground="{StaticResource Danger}" FontSize="15" Margin="0,0,6,0"/>
                    <TextBlock Text="Not running as Administrator — some PIDs and HTTP capture will be limited."
                               Foreground="{StaticResource Danger}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Status bar ================= -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderClr}"
                BorderThickness="0,1,0,0" Padding="12,5">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="   |   " Foreground="{StaticResource SubText}"/>
                    <TextBlock Text="{Binding Stats}" Foreground="{StaticResource SubText}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding HttpStatus}" Foreground="{StaticResource SubText}"/>
                    <TextBlock Text="   •   " Foreground="{StaticResource BorderClr}"/>
                    <TextBlock Text="{Binding OutboundHttpStatus}" Foreground="{StaticResource SubText}"/>
                    <TextBlock Text="    Last update: " Foreground="{StaticResource SubText}"/>
                    <TextBlock Text="{Binding LastUpdateText}" Foreground="{StaticResource Text}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Tabs ================= -->
        <TabControl Margin="8" BorderThickness="1">

            <!-- Connections tab -->
            <TabItem Header="🔌  Connections (All Traffic)">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" BorderBrush="{StaticResource BorderClr}"
                            BorderThickness="0,0,0,1" Padding="10,8">
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="Search (host / IP / process):" Margin="0,0,6,0" Foreground="{StaticResource SubText}"/>
                            <TextBox Width="230" Margin="0,0,16,0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Port:" Margin="0,0,6,0" Foreground="{StaticResource SubText}"/>
                            <TextBox Width="80" Margin="0,0,16,0"
                                     Text="{Binding PortFilter, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Direction:" Margin="0,0,6,0" Foreground="{StaticResource SubText}"/>
                            <ComboBox Width="110" Margin="0,0,16,0"
                                      ItemsSource="{Binding DirectionOptions}" SelectedItem="{Binding SelectedDirection}"/>

                            <TextBlock Text="Protocol:" Margin="0,0,6,0" Foreground="{StaticResource SubText}"/>
                            <ComboBox Width="80" Margin="0,0,16,0"
                                      ItemsSource="{Binding ProtocolOptions}" SelectedItem="{Binding SelectedProtocol}"/>

                            <CheckBox Content="Active only" IsChecked="{Binding ActiveOnly}"/>
                        </WrapPanel>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" MinHeight="140"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1*" MinHeight="110"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding ConnectionsView}"
                                  SelectedItem="{Binding SelectedConnection}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Width="72">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="FirstSeen" StringFormat="HH:mm:ss"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Direction" Width="98">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DirectionText}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TrafficDirection.Inbound}">
                                                                <Setter Property="Foreground" Value="{StaticResource Inbound}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TrafficDirection.Outbound}">
                                                                <Setter Property="Foreground" Value="{StaticResource Outbound}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TrafficDirection.Listening}">
                                                                <Setter Property="Foreground" Value="{StaticResource Listening}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TrafficDirection.Local}">
                                                                <Setter Property="Foreground" Value="{StaticResource SubText}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="58"/>
                                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="130"/>
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="58"/>
                                <DataGridTextColumn Header="Local" Binding="{Binding LocalEndpoint}" Width="160"/>
                                <DataGridTextColumn Header="Remote IP" Binding="{Binding RemoteAddress}" Width="135"/>
                                <DataGridTextColumn Header="Remote Host (domain)" Binding="{Binding RemoteHost}" Width="*"/>
                                <DataGridTextColumn Header="Country" Binding="{Binding CountryDisplay}" Width="150"/>
                                <DataGridTextColumn Header="Port" Binding="{Binding RemotePort}" Width="62"/>
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="92"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="74"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" Height="6" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                      HorizontalAlignment="Stretch" Background="{StaticResource BorderClr}"/>

                        <Border Grid.Row="2" Background="{StaticResource Panel}" Padding="14,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Style="{StaticResource DetailHeader}" Text="CONNECTION DETAILS"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid DataContext="{Binding SelectedConnection}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Direction"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding DirectionText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Protocol"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding Protocol, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Process / PID"/>
                                        <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding ProcessName, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Local endpoint"/>
                                        <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding LocalEndpoint, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Remote IP"/>
                                        <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding RemoteAddress, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Remote host"/>
                                        <TextBox   Grid.Row="5" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding RemoteHost, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Country"/>
                                        <TextBox   Grid.Row="6" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding CountryDisplay, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Remote port"/>
                                        <TextBox   Grid.Row="7" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding RemotePort, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="State"/>
                                        <TextBox   Grid.Row="8" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding State, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Duration"/>
                                        <TextBox   Grid.Row="9" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding DurationText, Mode=OneWay}"/>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Inbound HTTP tab -->
            <TabItem Header="🌐  Inbound HTTP (IIS / HTTP.sys)">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" BorderBrush="{StaticResource BorderClr}"
                            BorderThickness="0,0,0,1" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Filter (URL / method / status):" Margin="0,0,6,0" Foreground="{StaticResource SubText}"/>
                            <TextBox Width="300" Margin="0,0,16,0"
                                     Text="{Binding HttpSearch, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="🗑  Clear" Command="{Binding ClearHttpCommand}"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" MinHeight="140"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1*" MinHeight="110"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding HttpView}"
                                  SelectedItem="{Binding SelectedHttp}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="100"/>

                                <DataGridTemplateColumn Header="Status" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="Success">
                                                                <Setter Property="Foreground" Value="{StaticResource Inbound}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="Redirect">
                                                                <Setter Property="Foreground" Value="{StaticResource Listening}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="ClientError">
                                                                <Setter Property="Foreground" Value="{StaticResource Outbound}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="ServerError">
                                                                <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="Pending">
                                                                <Setter Property="Foreground" Value="{StaticResource SubText}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="76"/>
                                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" Height="6" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                      HorizontalAlignment="Stretch" Background="{StaticResource BorderClr}"/>

                        <Border Grid.Row="2" Background="{StaticResource Panel}" Padding="14,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Style="{StaticResource DetailHeader}" Text="REQUEST DETAILS (inbound)"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid DataContext="{Binding SelectedHttp}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Time"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding TimeText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Method"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding Method, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Status"/>
                                        <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding StatusText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="URL"/>
                                        <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding Url, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Duration"/>
                                        <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding DurationText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0" FontStyle="Italic"
                                                   Foreground="{StaticResource SubText}" TextWrapping="Wrap"
                                                   Text="Body &amp; header values are not captured via ETW. Capturing them requires proxy mode."/>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Outbound HTTP tab -->
            <TabItem Header="📡  Outbound HTTP (App → APIs)">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" BorderBrush="{StaticResource BorderClr}"
                            BorderThickness="0,0,0,1" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Filter (URL / host / status / process):" Margin="0,0,6,0" Foreground="{StaticResource SubText}"/>
                            <TextBox Width="300" Margin="0,0,16,0"
                                     Text="{Binding OutboundHttpSearch, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="🗑  Clear" Command="{Binding ClearOutboundHttpCommand}"/>
                            <TextBlock Text="  Captures HttpClient calls from .NET apps (e.g. w3wp) — full URL + status, no proxy."
                                       Foreground="{StaticResource SubText}" FontStyle="Italic" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" MinHeight="140"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1*" MinHeight="110"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding OutboundHttpView}"
                                  SelectedItem="{Binding SelectedOutbound}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="100"/>

                                <DataGridTemplateColumn Header="Status" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="Success">
                                                                <Setter Property="Foreground" Value="{StaticResource Inbound}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="Redirect">
                                                                <Setter Property="Foreground" Value="{StaticResource Listening}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="ClientError">
                                                                <Setter Property="Foreground" Value="{StaticResource Outbound}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="ServerError">
                                                                <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCategory}" Value="Pending">
                                                                <Setter Property="Foreground" Value="{StaticResource SubText}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                                <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="190"/>
                                <DataGridTextColumn Header="Process (caller)" Binding="{Binding ProcessDisplay}" Width="170"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding DurationText}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" Height="6" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                      HorizontalAlignment="Stretch" Background="{StaticResource BorderClr}"/>

                        <Border Grid.Row="2" Background="{StaticResource Panel}" Padding="14,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Style="{StaticResource DetailHeader}" Text="REQUEST DETAILS (outbound)"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid DataContext="{Binding SelectedOutbound}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Time"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding TimeText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Status"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding StatusText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="URL"/>
                                        <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding Url, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Host"/>
                                        <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding Host, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Process / PID"/>
                                        <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding ProcessDisplay, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Duration"/>
                                        <TextBox   Grid.Row="5" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding DurationText, Mode=OneWay}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0" FontStyle="Italic"
                                                   Foreground="{StaticResource SubText}" TextWrapping="Wrap"
                                                   Text="Body &amp; header values are not exposed by the runtime telemetry. Capturing them requires proxy mode."/>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
